.projectCardWrapper {
  width: 100%;
}

.projectCard {
  display: flex;
  flex-direction: row;
  width: 100%;
  overflow: hidden;
}

.projectImage {
  flex: 0 0 50%;
  width: 50%;
  display: block;
}

.projectHero {
  width: 100%;
  height: 100%;
  position: relative;
}

.heroImage {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.projectDeets {
  flex: 0 0 50%;
  width: 50%;
  padding: 2rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Medium breakpoint and below */
@media (max-width: 768px) {
  .projectCard {
    flex-direction: column;
  }
  
  .projectImage,
  .projectDeets {
    flex: 0 0 100%;
    width: 100%;
  }
  
  .projectDeets {
    padding: 1.5rem;
  }
}
